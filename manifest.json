{
  "manifest_version": 3,
  "name": "직방 데이터 스크래퍼",
  "version": "1.1",
  "description": "직방 매물 리스트 + 매물별 상세 페이지(주소·면적·승인일 등)를 수집해 CSV로 저장합니다.",
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "downloads"
  ],
  "host_permissions": [
    "*://*.zigbang.com/*"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  }
}